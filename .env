# GitHub OAuth Configuration
VITE_GITHUB_CLIENT_ID=your_github_client_id
VITE_GITHUB_CLIENT_SECRET=your_github_client_secret
VITE_GITHUB_REDIRECT_URI=https://your-gitpilot-app.netlify.app/auth/callback
VITE_GITHUB_SCOPES=user:email,repo,delete_repo,admin:org

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API Endpoints
VITE_API_BASE_URL=https://api.github.com
VITE_FIREBASE_FUNCTIONS_URL=https://us-central1-your-project-id.cloudfunctions.net

# Application Settings
VITE_APP_NAME=GitPilot
VITE_APP_URL=https://your-gitpilot-app.netlify.app
VITE_NODE_ENV=development

# IMPORTANT: This file contains sensitive information and should be added to .gitignore
# Create a .env.example file with these variables but without the actual values for version control
