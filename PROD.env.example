# GitPilot Production Environment Template

# App
NEXTAUTH_URL=https://your-app-url.com
NEXTAUTH_SECRET=your-long-random-secret-here

# GitHub OAuth (Create a GitHub App for production)
GITHUB_ID=your-prod-github-id
GITHUB_SECRET=your-prod-github-secret

# Database (Neon Connection String)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional
NODE_ENV=production
# SENTRY_DSN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
